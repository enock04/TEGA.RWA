# Application
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tega_rw_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT — use separate, strong random secrets (min 32 chars each)
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min32chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your_different_refresh_secret_key_min32chars
JWT_REFRESH_EXPIRES_IN=30d

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@tega.rw

# SMS Gateway (Twilio)
# Leave TWILIO_ACCOUNT_SID as AC_mock to stay in log-only mode
TWILIO_ACCOUNT_SID=AC_mock
TWILIO_AUTH_TOKEN=mock_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# MTN MoMo (Mock for MVP)
MOMO_API_KEY=mock_momo_key
MOMO_SUBSCRIPTION_KEY=mock_subscription_key
MOMO_ENVIRONMENT=sandbox
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com

# Airtel Money (Mock for MVP)
AIRTEL_CLIENT_ID=mock_client_id
AIRTEL_CLIENT_SECRET=mock_client_secret
AIRTEL_BASE_URL=https://openapiuat.airtel.africa

# Frontend URL (for CORS) — comma-separated for multiple origins
FRONTEND_URL=http://localhost:3000

# Webhook secret — must match X-Webhook-Secret header from payment providers
WEBHOOK_SECRET=your_webhook_secret_change_in_production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

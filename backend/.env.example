# Application
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tega_rw_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@tega.rw

# SMS Gateway (Mock for MVP)
SMS_API_KEY=mock_sms_key
SMS_SENDER_ID=TEGA.Rw

# MTN MoMo (Mock for MVP)
MOMO_API_KEY=mock_momo_key
MOMO_SUBSCRIPTION_KEY=mock_subscription_key
MOMO_ENVIRONMENT=sandbox
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com

# Airtel Money (Mock for MVP)
AIRTEL_CLIENT_ID=mock_client_id
AIRTEL_CLIENT_SECRET=mock_client_secret
AIRTEL_BASE_URL=https://openapiuat.airtel.africa

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

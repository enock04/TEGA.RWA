# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
NODE_OPTIONS=--dns-result-order=ipv4first

# ── Database (Supabase) ───────────────────────────────────────────────────────
DB_HOST=aws-1-eu-west-3.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.ujphhjdrnuolxtddpkzs
DB_PASSWORD=CHANGE_ME

# ── JWT — generate strong random secrets: openssl rand -hex 64 ────────────────
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS (must match your real domains) ───────────────────────────────────────
FRONTEND_URL=https://app.tega.rw,https://agency.tega.rw,https://admin.tega.rw

# ── Email (use SendGrid or AWS SES in production) ─────────────────────────────
EMAIL_FROM=noreply@tega.rw
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME_SENDGRID_API_KEY

# ── SMS (Africa's Talking) ────────────────────────────────────────────────────
SMS_API_KEY=CHANGE_ME_AT_API_KEY
SMS_SENDER_ID=TEGA.Rw

# ── Payments (MTN MoMo sandbox → live) ───────────────────────────────────────
MOMO_BASE_URL=https://proxy.momoapi.mtn.com
MOMO_SUBSCRIPTION_KEY=CHANGE_ME
MOMO_API_USER=CHANGE_ME
MOMO_API_KEY=CHANGE_ME
MOMO_ENVIRONMENT=production

# ── Payments (Airtel Money) ───────────────────────────────────────────────────
AIRTEL_BASE_URL=https://openapi.airtel.africa
AIRTEL_CLIENT_ID=CHANGE_ME
